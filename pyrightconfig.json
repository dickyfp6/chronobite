{
  "pythonVersion": "3.9",
  "typeCheckingMode": "basic",
  "include": [
    "."
  ],
  "exclude": [
    ".venv",
    "**/__pycache__"
  ],
  "ignore": [
    ".venv/**",
    "c:\\__pyrefly_virtual__\\**"
  ],
  "pythonPath": ".",
  "useLibraryCodeForTypes": false,
  "extraPaths": [
    "C. System Flow",
    "D. Model",
    "F. WebApp"
  ],
  "reportMissingImports": true,
  "reportMissingModuleSource": false,
  "reportOptionalMemberAccess": "none",
  "reportOptionalSubscript": "none"
}